# Django Settings
DJANGO_SECRET_KEY=your-secret-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,postgres
TIME_ZONE=UTC
DJANGO_SETTINGS_MODULE=backend.settings.dev

# Database (matches docker-compose.yml)
DB_HOST=postgres
DB_PORT=5433
DB_NAME=potter_dev
DB_USER=potter
DB_PASSWORD=potterpass
DATABASE_URL=postgres://potter:potterpass@postgres:5432/potter_dev

# Email (for later phases)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False

# Redis (for later phases)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# S3 / MinIO (for later phases)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_STORAGE_BUCKET_NAME=pottershouse
AWS_S3_REGION_NAME=us-east-1
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_DEFAULT_ACL=public-read

# Idempotency (for later phases)
IDEMPOTENCY_TTL=86400

# Sentry (for later phases)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_RELEASE=

# Monitoring
ENABLE_METRICS=False
PAGERDUTY_ROUTING_KEY=

# Rate limiting
BOOKINGS_RATE_LIMIT=60
BOOKINGS_RATE_WINDOW=3600
USE_REDIS_CACHE=False
RATE_LIMIT_FAIL_OPEN=True

# Auth / JWT
USE_REFRESH_COOKIE=True
REFRESH_COOKIE_NAME=pottershouse_refresh
REFRESH_COOKIE_SECURE=False
REFRESH_COOKIE_SAMESITE=Lax
REFRESH_COOKIE_PATH=/api/v1/admin/refresh
REFRESH_COOKIE_MAX_AGE=604800
FRONTEND_PASSWORD_RESET_URL=https://pottershouse.example.com/admin/reset-password
PASSWORD_RESET_TIMEOUT=1800

# Logging
LOG_LEVEL=DEBUG

# CORS (if you have a separate frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Pagination
DEFAULT_PAGE_SIZE=20

DEFAULT_FROM_EMAIL=no-reply@pottershouse.example.com
EMAIL_USE_SSL=False
WHATSAPP_CONTACT_LINK=https://wa.me/639171234567?text=Hello
